rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/progress/current
    // Document ID: current
    // Fields:
    //   - currentDay: number (required) - The current day the user is on.
    //   - completedExercises: list (required) - List of specific exercise IDs completed.
    //   - completionHistory: list (required) - History of exercise completions.
    //   - updatedAt: timestamp (optional) - The last time the progress was updated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "anderssonjorge52@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidProgress(data) {
      return data.currentDay is number &&
             data.currentDay >= 1 &&
             data.completedExercises is list &&
             data.completedExercises.size() <= 1000 &&
             data.completionHistory is list &&
             data.completionHistory.size() <= 1000 &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      match /progress/{progressId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidProgress(request.resource.data);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
