{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user progress and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "completedExercises": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of completed exercises."
        },
        "completionHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "exerciseId": { "type": "string" },
              "completedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["exerciseId", "completedAt"]
          },
          "description": "History of exercise completions."
        },
        "currentDay": { "type": "integer", "description": "The current day in the program." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last time the profile was updated." }
      },
      "required": ["uid", "email", "completedExercises", "completionHistory", "currentDay"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
